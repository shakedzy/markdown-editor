{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node",
    "target": "ES2022",
    "outDir": "dist-main",
    "rootDir": "src",
    "sourceMap": true,
    "declaration": false,
    "types": ["node"],
    "lib": ["ES2022"]
  },
  "include": ["src/main/**/*", "src/preload/**/*", "src/shared/**/*"]
}
