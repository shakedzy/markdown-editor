{
  "name": "mditor",
  "version": "0.1.0",
  "description": "Cross-platform markdown editor and viewer (Electron + React + CodeMirror).",
  "author": {
    "name": "Shaked Zychlinski",
    "email": "shakedz@jfrog.com"
  },
  "license": "MIT",
  "main": "dist-main/main/main.js",
  "scripts": {
    "dev": "concurrently -k -n vite,electron -c blue,green \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:renderer": "vite",
    "dev:electron": "wait-on http://localhost:5173 && tsc -p tsconfig.main.json && npm run build:preload && cross-env NODE_ENV=development electron dist-main/main/main.js",
    "build": "npm run build:renderer && npm run build:main",
    "build:renderer": "vite build",
    "build:main": "tsc -p tsconfig.main.json && npm run build:preload",
    "build:preload": "esbuild src/preload/preload.ts --bundle --platform=node --target=node20 --format=cjs --external:electron --outfile=dist-main/preload/preload.js",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "dist:mac": "npm run build && electron-builder --mac --arm64",
    "dist:win": "npm run build && electron-builder --win --x64",
    "dist:linux": "npm run build && electron-builder --linux --x64",
    "icons": "node scripts/generate-icons.mjs",
    "check-version": "node scripts/check-version.mjs",
    "typecheck": "tsc -p tsconfig.main.json --noEmit && tsc -p tsconfig.renderer.json --noEmit"
  },
  "dependencies": {
    "@codemirror/commands": "^6.6.0",
    "@codemirror/lang-markdown": "^6.3.0",
    "@codemirror/language": "^6.10.3",
    "@codemirror/language-data": "^6.5.1",
    "@codemirror/search": "^6.5.6",
    "@codemirror/state": "^6.4.1",
    "@codemirror/view": "^6.34.1",
    "dompurify": "^3.1.7",
    "github-slugger": "^2.0.0",
    "gemoji": "^8.1.0",
    "highlight.js": "^11.10.0",
    "katex": "^0.16.11",
    "marked": "^14.1.3",
    "marked-alert": "^2.1.2",
    "marked-emoji": "^2.0.1",
    "marked-footnote": "^1.2.4",
    "marked-highlight": "^2.2.1",
    "marked-katex-extension": "^5.1.4",
    "mermaid": "^11.4.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/dompurify": "^3.0.5",
    "@types/node": "^20.16.10",
    "@types/react": "^18.3.10",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.0.1",
    "cross-env": "^7.0.3",
    "electron": "^32.1.2",
    "electron-builder": "^25.0.5",
    "png-to-ico": "^2.1.8",
    "sharp": "^0.33.5",
    "typescript": "^5.6.2",
    "vite": "^5.4.8",
    "wait-on": "^8.0.1"
  },
  "engines": {
    "node": ">=20"
  }
}
